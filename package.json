{
  "name": "paddle-ocr",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @paddle-ocr/web dev",
    "build": "pnpm --filter @paddle-ocr/web build",
    "start": "pnpm --filter @paddle-ocr/web start",
    "predev": "pnpm --filter @paddle-ocr/shared build",
    "typecheck": "pnpm run -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
